{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,

    "strict": true,

    "noEmit": true,

    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": ["ESNext", "DOM"],

    "paths": {
      "$taut": ["./shared/Plugin.ts"],
      "*": ["./*"]
    },

    "jsx": "react",

    "types": ["bun", "node", "chrome", "firefox-webext-browser"],
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.cjs"],
  "exclude": [
    "node_modules",
    "**/deps/",
    "dist",
    "tmp*",
    "extension/chrome/taut.js",
    "extension/firefox/taut.js",
    "server"
  ]
}
