{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "taut-server",
  "compatibility_date": "2026-06-09",
  "main": "src/index.ts",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "compatibility_flags": ["nodejs_compat"]
}
