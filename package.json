{
  "name": "taut",
  "version": "2.0.0",
  "description": "Client mod for Slack",
  "license": "MIT",
  "author": {
    "name": "Jeremy Woolley",
    "email": "taut@jeremywoolley.com",
    "url": "https://jeremywoolley.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremy46231/taut"
  },
  "homepage": "https://github.com/jeremy46231/taut",
  "bugs": "https://github.com/jeremy46231/taut/issues",
  "type": "module",
  "scripts": {
    "build": "bun run build:taut && bun run build:extension && bun run build:userscript",
    "build:taut": "bun ./scripts/buildTaut.ts",
    "build:extension": "bun ./scripts/buildExtension.ts",
    "build:userscript": "bun ./scripts/buildUserscript.ts",
    "build:desktop": "bun ./scripts/buildDesktop.ts",
    "dev": "bun ./scripts/serveTaut.ts",
    "format": "prettier --write .",
    "server:dev": "wrangler dev --config server/wrangler.jsonc",
    "server:deploy": "wrangler deploy --config server/wrangler.jsonc"
  },
  "keywords": [
    "taut",
    "slack",
    "mod",
    "patcher"
  ],
  "devDependencies": {
    "@monaco-editor/loader": "^1.7.0",
    "@types/bun": "^1.3.5",
    "@types/chrome": "^0.1.43",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "bun": "^1.3.3",
    "electron": "42.2.0",
    "electron-builder": "^26.0.0",
    "electron-devtools-installer": "^4.0.0",
    "esbuild": "^0.27.0",
    "fflate": "^0.8.3",
    "jsonc-parser": "^3.3.1",
    "monaco-editor": "^0.55.1",
    "prettier": "^3.7.3",
    "typescript": "^5.9.3",
    "@cloudflare/workers-types": "^4.20260609.1",
    "wrangler": "^4.98.0"
  }
}
