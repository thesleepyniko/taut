{
  "manifest_version": 2,
  "name": "Taut",
  "version": "1.3.0",
  "description": "Client mod for Slack",
  "author": "Jeremy Woolley",
  "homepage_url": "https://taut.jer.app",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": { "id": "taut@jer.app", "strict_min_version": "128.0" }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "cookies",
    "https://*.slack.com/*"
  ],
  "optional_permissions": ["*://*/*"],
  "options_ui": {
    "page": "options.html",
    "browser_style": false
  },
  "background": { "scripts": ["background.js"] },
  "content_scripts": [
    {
      "matches": ["https://app.slack.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": ["bridge-setup.js"]
}
